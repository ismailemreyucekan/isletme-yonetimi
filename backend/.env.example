# ---- Uygulama ----
APP_NAME=Kasa
ENVIRONMENT=development           # development | production
DEBUG=true

# ---- Veritabanı (async SQLAlchemy) ----
# Docker compose içinde host = "db". Yerelde "localhost".
DATABASE_URL=postgresql+asyncpg://kasa:kasa@localhost:5432/kasa

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- Güvenlik / JWT ----
# Üretimde MUTLAKA güçlü, rastgele bir değerle değiştirin:  openssl rand -hex 32
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# ---- CORS ----
# Virgülle ayrılmış origin listesi
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
